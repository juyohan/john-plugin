{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/pre-bash-dispatcher.js"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js pre:write:doc-file-warning scripts/hooks/doc-file-warning.js standard,strict"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js pre:edit-write:suggest-compact scripts/hooks/suggest-compact.js standard,strict"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js pre:config-protection scripts/hooks/config-protection.js standard,strict",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js pre:edit-write:gateguard-fact-force scripts/hooks/gateguard-fact-force.js standard,strict",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js pre:compact scripts/hooks/pre-compact.js standard,strict"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/stop-hook-runner.js session:start scripts/hooks/session-start.js minimal,standard,strict 30000"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/post-bash-dispatcher.js",
            "async": true,
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js post:quality-gate scripts/hooks/quality-gate.js standard,strict",
            "async": true,
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js post:edit:design-quality-check scripts/hooks/design-quality-check.js strict",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/run-with-flags.js post:edit:accumulate scripts/hooks/post-edit-accumulator.js standard,strict"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/pre-hook-runner.js node scripts/hooks/doc-frontmatter.js",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/stop-hook-runner.js stop:format-typecheck scripts/hooks/stop-format-typecheck.js standard,strict 300000",
            "timeout": 300
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/stop-hook-runner.js stop:check-console-log scripts/hooks/check-console-log.js standard,strict 30000"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/stop-hook-runner.js stop:session-end scripts/hooks/session-end.js minimal,standard,strict 30000",
            "async": true,
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/stop-hook-runner.js stop:cost-tracker scripts/hooks/cost-tracker.js minimal,standard,strict 30000",
            "async": true,
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $PLUGIN_ROOT/scripts/hooks/stop-hook-runner.js stop:desktop-notify scripts/hooks/desktop-notify.js standard,strict 30000",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
