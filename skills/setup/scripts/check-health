#!/usr/bin/env bash
# Genie Plugin — environment health check + auto-setup
# Active mode: auto-installs missing required tools, auto-updates plugin if outdated.
# Exit 0: all required tools ready. Exit 1: tool install failed.

set -o pipefail

# =====================================================
#  Helpers
# =====================================================

ok()      { echo "  🟢  $1"; }
warn()    { echo "  🟡  $1"; }
fail()    { echo "  🔴  $1"; }
detail()  { echo "       $1"; }
section() { printf "\n %s\n" "$1"; }

# =====================================================
#  Plugin root + version
# =====================================================

PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

PLUGIN_VERSION="unknown"
if command -v jq >/dev/null 2>&1; then
  PLUGIN_VERSION=$(jq -r '.version' "$PLUGIN_DIR/.claude-plugin/plugin.json" 2>/dev/null || echo "unknown")
fi

# =====================================================
#  Dependency config
# =====================================================
# Format: name|brew_pkg
# To add a dependency: add a line here. No other changes needed.

deps=(
  "gh|gh"
  "jq|jq"
)

# =====================================================
#  Required tools (auto-install on missing)
# =====================================================

has_brew=$(command -v brew >/dev/null 2>&1 && echo "yes" || echo "no")

cli_ok=0
cli_total=${#deps[@]}
install_failed=0

tool_results=()
for entry in "${deps[@]}"; do
  IFS='|' read -r name brew_pkg <<< "$entry"
  if command -v "$name" >/dev/null 2>&1; then
    cli_ok=$((cli_ok + 1))
    tool_results+=("$name|ok")
  else
    tool_results+=("$name|missing|$brew_pkg")
  fi
done

# =====================================================
#  Skills (from skills/ directory)
# =====================================================

skill_names=()
if [ -d "$PLUGIN_DIR/skills" ]; then
  while IFS= read -r -d '' dir; do
    name="$(basename "$dir")"
    [ "$name" = "SKILL.md" ] && continue
    skill_names+=("$name")
  done < <(find "$PLUGIN_DIR/skills" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
fi

skill_total=${#skill_names[@]}

# =====================================================
#  Version check
# =====================================================

version_status="skip"   # skip | ok | updated | error
old_head=""
new_head=""
update_log=""

if git -C "$PLUGIN_DIR" rev-parse --git-dir >/dev/null 2>&1; then
  old_head=$(git -C "$PLUGIN_DIR" rev-parse HEAD 2>/dev/null)

  if git -C "$PLUGIN_DIR" fetch origin main --quiet 2>/dev/null; then
    remote_head=$(git -C "$PLUGIN_DIR" rev-parse origin/main 2>/dev/null)

    if [ "$old_head" = "$remote_head" ]; then
      version_status="ok"
    else
      # Ask for consent before updating
      printf " 새 버전이 있습니다. 지금 업데이트할까요? [y/N] "
      read -r user_consent </dev/tty 2>/dev/null || user_consent="n"
      if [[ ! "$user_consent" =~ ^[Yy]$ ]]; then
        version_status="skip"
      # Run update with consent
      elif bash "$PLUGIN_DIR/update.sh" >/dev/null 2>&1; then
        new_head=$(git -C "$PLUGIN_DIR" rev-parse HEAD 2>/dev/null)
        update_log=$(git -C "$PLUGIN_DIR" log "$old_head..$new_head" --oneline --pretty=format:"  · %s" 2>/dev/null | head -10)
        extra=$(git -C "$PLUGIN_DIR" log "$old_head..$new_head" --oneline 2>/dev/null | wc -l | tr -d ' ')
        [ "$extra" -gt 10 ] && update_log="$update_log"$'\n'"  · ... 외 $((extra - 10))개"
        PLUGIN_VERSION=$(jq -r '.version' "$PLUGIN_DIR/.claude-plugin/plugin.json" 2>/dev/null || echo "unknown")
        version_status="updated"
      else
        version_status="error"
      fi
    fi
  else
    version_status="error"
  fi
fi

# =====================================================
#  Output
# =====================================================

echo ""

# Header
if [ "$version_status" = "updated" ]; then
  old_version=$(git -C "$PLUGIN_DIR" show "$old_head:.claude-plugin/plugin.json" 2>/dev/null | grep '"version"' | head -1 | sed 's/.*"\([^"]*\)".*/\1/' || echo "?")
  echo " Genie Plugin v${old_version} → v${PLUGIN_VERSION}"
else
  echo " Genie Plugin v${PLUGIN_VERSION}"
fi

# --- Tools ---
section "도구  ${cli_ok}/${cli_total}"

for result in "${tool_results[@]}"; do
  IFS='|' read -r name status brew_pkg <<< "$result"
  if [ "$status" = "ok" ]; then
    ok "$name"
  else
    warn "$name"
    detail "$name 설치 중..."

    if [ "$has_brew" = "no" ]; then
      fail "$name 설치 실패 — brew가 없습니다. https://brew.sh 에서 설치 후 다시 실행해주세요."
      install_failed=1
      continue
    fi

    if NONINTERACTIVE=1 HOMEBREW_NO_AUTO_UPDATE=1 brew install -q "$brew_pkg" 2>/dev/null; then
      cli_ok=$((cli_ok + 1))
      detail "✅ $name 설치 완료"

      # jq가 방금 설치됐으면 버전 재시도
      if [ "$name" = "jq" ] && [ "$PLUGIN_VERSION" = "unknown" ]; then
        PLUGIN_VERSION=$(jq -r '.version' "$PLUGIN_DIR/.claude-plugin/plugin.json" 2>/dev/null || echo "unknown")
      fi
    else
      fail "$name 설치 실패 — 수동으로 설치 후 다시 실행해주세요."
      install_failed=1
    fi
  fi
done

# --- Skills ---
section "스킬  ${skill_total}/${skill_total}"

col=0
line=""
for name in "${skill_names[@]}"; do
  entry=$(printf "  🟢  %-22s" "$name")
  line="${line}${entry}"
  col=$((col + 1))
  if [ "$col" -eq 3 ]; then
    echo "$line"
    line=""
    col=0
  fi
done
[ -n "$line" ] && echo "$line"

# --- Version ---
echo ""
case "$version_status" in
  ok)
    echo " ✅ 최신 버전"
    ;;
  updated)
    echo " 업데이트 완료"
    if [ -n "$update_log" ]; then
      echo ""
      echo " 변경 사항:"
      echo "$update_log"
    fi
    ;;
  error)
    echo " ⚠️  버전 확인 불가 (네트워크 또는 업데이트 오류)"
    ;;
  skip)
    echo " ⚠️  버전 확인 불가 (git 저장소 없음)"
    ;;
esac

echo ""

# =====================================================
#  Exit
# =====================================================

if [ "$install_failed" -eq 1 ]; then
  exit 1
fi

exit 0
